# API keys — only the key for your chosen provider is required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
XAI_API_KEY=your_xai_api_key_here

# Default provider and model (overridden by --provider / --model flags)
# Supported providers: anthropic, openai, google, xai
DEFAULT_PROVIDER=anthropic
# If omitted, the provider's default model is used (e.g. claude-sonnet-4-6 for anthropic)
DEFAULT_MODEL=claude-sonnet-4-6

# Optional: web server port (default: 3000)
PORT=3000
